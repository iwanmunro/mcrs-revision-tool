# ─────────────────────────────────────────────────────────────────────────────
# MRCS Revision Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────────────────
# User accounts as a JSON object: {"username": "password", ...}
# Add or remove users by editing this value on the server.
USERS={"admin": "changeme"}

# Long random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# How long a login session lasts (in minutes). Default: 480 (8 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
# When running via Docker Compose this is set automatically; only change if
# running the backend directly on the host.
OLLAMA_BASE_URL=http://localhost:11434

# Model to use. Must be pulled first: `ollama pull llama3.2`
# CPU-friendly options (smallest → largest):
#   llama3.2:1b     (~1.3 GB, fastest, recommended default)
#   llama3.2        (~2 GB, better quality)
#   phi3.5          (~2.3 GB, strong reasoning)
#   llama3.1:8b     (~4.7 GB, highest quality, slow on CPU)
OLLAMA_MODEL=llama3.2:1b

# ── Embeddings ────────────────────────────────────────────────────────────────
# Sentence-transformers model used for document embeddings.
# all-MiniLM-L6-v2 is small, fast, and runs entirely on CPU.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG settings ─────────────────────────────────────────────────────────────
# Number of document chunks retrieved per query.
RETRIEVAL_TOP_K=5
# Size of each text chunk (in characters).
CHUNK_SIZE=600
# Overlap between consecutive chunks.
CHUNK_OVERLAP=100

# ── Paths (Docker default; change only if running bare-metal) ─────────────────
CHROMA_PERSIST_DIR=./chroma_db
KNOWLEDGE_BASE_DIR=./knowledge_bases

# ── App port ─────────────────────────────────────────────────────────────────
# Port the frontend is exposed on when using Docker Compose.
APP_PORT=3000
